{
  "name": "tracy",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "make dist",
    "build:cov": "make wasm-cov",
    "bench:app-load": "node tools/app-load-bench.js",
    "lhci": "make lighthouse-ci",
    "lhci:autorun": "lhci autorun --config=.lighthouserc.cjs",
    "playwright:install": "playwright install --with-deps",
    "playwright:test": "playwright test",
    "test": "make test",
    "test:node": "vitest run",
    "test:layout": "node tools/generate-layout.js --check",
    "test:host-abi": "node tools/generate-host-abi.js --check",
    "test:palette-spec": "node tools/generate-palette-spec.js --check",
    "test:parser-state-abi": "node tools/generate-parser-state-abi.js --check",
    "test:runtime-spec": "node tools/generate-runtime-spec.js --check",
    "test:wasm-modules-abi": "node tools/extract-wasm-modules.js --check",
    "test:wasm-modules-loader": "node tools/generate-wasm-modules-abi.js --check",
    "test:bootstrap-lines": "bash tools/check-bootstrap-lines.sh",
    "test:wasm-modules": "node tools/wasm-modules-check.js",
    "test:ingest-worker-runtime": "node tools/ingest-worker-runtime-check.js",
    "test:runtime-worker": "node tools/runtime-worker-orchestration-check.js",
    "test:production-topology-fixture": "node tools/production-topology-fixture-check.js",
    "test:interactive-ingest-browser": "node tools/interactive-ingest-browser-check.js",
    "test:direct-esm": "node tools/direct-esm-check.js",
    "test:dist-browser-helpers": "node tools/dist-browser-helpers-check.js",
    "test:generated-file-writer": "vitest run",
    "test:dist-budget": "node tools/dist-budget-check.js --self-test",
    "test:app-load-bench": "node tools/app-load-bench.js --self-test",
    "test:lighthouse-ci": "node tools/lighthouse-ci-check.js",
    "test:generated-trace": "node tools/generated-trace-extractor-check.js",
    "test:cold-reload-index": "node tools/cold-reload-index-check.js",
    "test:coverage-selftest": "node tools/coverage-selftest.js",
    "test:coverage": "WAT_COVERAGE_CHECK=1 vitest run tools/wat-coverage.test.mjs",
    "test:coverage:report": "vitest run tools/wat-coverage.test.mjs",
    "test:coverage:strict": "WAT_COVERAGE_CHECK=1 vitest run tools/wat-coverage.test.mjs",
    "coverage": "make coverage",
    "coverage:strict": "make coverage-strict"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.59.1",
    "puppeteer-core": "24.43.0",
    "vitest": "^4.1.6"
  }
}
